# ── Browser engine ────────────────────────────────────────────────────────────
# Leave blank to use local Playwright (requires: playwright install chromium)
# Set to use Browserless.io cloud rendering (free tier: 100 pages/month)
BROWSERLESS_API_KEY=

# Optional: Override Browserless endpoint (e.g. for self-hosted Browserless)
BROWSERLESS_URL=https://chrome.browserless.io

# ── API server ────────────────────────────────────────────────────────────────
PORT=8000

# ── Storage backend ───────────────────────────────────────────────────────────
# "json"   → stores data/items.json + data/config.json (default, zero config)
# "sqlite" → stores data/tracker.db (enables price history tracking)
STORAGE_BACKEND=json
