# Environment Variables for Price Tracker API
# Copy this to .env and fill in your values

# Browserless.io Configuration (for cloud-based Playwright)
# Get your API key from: https://www.browserless.io/
BROWSERLESS_API_KEY=your_browserless_api_key_here

# FastAPI Port (for local development)
PORT=8000

# RapidAPI Configuration (for testing authorization)
RAPIDAPI_API_KEY=your_rapidapi_key_here
RAPIDAPI_API_HOST=your-api-host.com
